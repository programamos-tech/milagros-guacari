# --- Supabase local (recomendado para empezar en limpio) ---
# 1) Instalá la CLI: https://supabase.com/docs/guides/cli
# 2) En la raíz del repo: `supabase start`
# 3) Copiá URL y anon key: `supabase status`
# API en puerto 57521 (no choca con el proyecto "tiendas" si lo tenés abierto).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:57521
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Supabase remoto (producción / preview) ---
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Contraseña de Postgres (Settings → Database). Solo local, para scripts como:
#   ./scripts/push-local-public-data-to-linked.sh
# SUPABASE_DB_PASSWORD=

# URL pública del sitio (checkout / Wompi). En local conviene definirla.
# En Vercel podés omitirla: se usa automáticamente VERCEL_URL (https://*.vercel.app del deploy).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Marca visible (default en código: Milagros Guacarí)
NEXT_PUBLIC_STORE_NAME=Milagros Guacarí
# Opcional — footer, barra superior e impresión de factura (tirilla)
# NEXT_PUBLIC_STORE_PHONE=+57 312 456 4191
# NEXT_PUBLIC_STORE_EMAIL=hola@milagrosguacari.com
# Razón social / NIT en cabecera de tirilla (si omitís LEGAL_NAME se usa STORE_NAME)
# NEXT_PUBLIC_STORE_LEGAL_NAME=Milagros Guacarí
# NEXT_PUBLIC_STORE_NIT=901.xxx.xxx-x
# NEXT_PUBLIC_STORE_TAX_REGIME=Responsables de IVA
# WhatsApp (si difiere del teléfono visible)
# NEXT_PUBLIC_WHATSAPP_NUMBER=573205848594
# NEXT_PUBLIC_WHATSAPP_TEXT=Hola, te escribo desde la tienda de Aleya Shop. Me gustaría recibir asesoría.
# Transferencia en checkout (opcional; hay defaults en código)
# NEXT_PUBLIC_TRANSFER_ACCOUNT_HOLDER=ALEYA SHOP SAS
# NEXT_PUBLIC_TRANSFER_TAX_ID=901.522.077
# NEXT_PUBLIC_TRANSFER_BANCOLOMBIA_ACCOUNT=111-000012-85
# NEXT_PUBLIC_TRANSFER_MOBILE_WALLET=3246868749

# Wompi Colombia — test o prod según WOMPI_ENV
WOMPI_ENV=sandbox
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_INTEGRITY_SECRET=
